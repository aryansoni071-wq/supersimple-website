        h1, h2, h3, .logo-font { font-family: 'Playfair Display', serif; }
        
        .gold-text {
            background: linear-gradient(to right, #D4AF37, #FFF2CD, #AA771C);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .gold-bg {
            background: linear-gradient(to right, #D4AF37, #AA771C);
        }
        
        .misty-gradient {
            background: radial-gradient(circle at top, #1a1a2e 0%, #050505 100%);
